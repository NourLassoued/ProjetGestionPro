pipeline {
    agent any

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }

    environment {
        DOCKER_REGISTRY = 'docker.io'
        DOCKER_IMAGE = 'nourlassoued/gestionprojeet'
        GIT_CREDENTIALS = 'github-token'
        DOCKER_CREDENTIALS = 'docker-credentials'
    }

    stages {
        stage('Pre-Checks') {
            steps {
                echo '========================================='
                echo 'PRE-CHECKS'
                echo '========================================='
                sh 'echo Branch: ${GIT_BRANCH}'
                sh 'echo Commit: ${GIT_COMMIT}'
                sh 'java -version'
                sh 'docker --version'
            }
        }

        stage('Checkout Code') {
            steps {
                echo '========================================='
                echo 'CHECKOUT CODE'
                echo '========================================='
                checkout scm
            }
        }

        stage('Build & Test') {
            steps {
                echo '========================================='
                echo 'BUILD & TEST WITH COVERAGE'
                echo '========================================='
                dir('backend') {
                    sh 'chmod +x ./mvnw'
                    sh './mvnw clean test jacoco:report'
                    sh './mvnw package -DskipTests'
                }
            }
            post {
                always {
                    // Publier résultats tests
                    junit '**/target/surefire-reports/*.xml'

                    // ✅ Publier coverage avec le plugin Coverage
                    publishCoverage adapters: [jacocoAdapter('**/target/site/jacoco/jacoco.xml')]
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                echo '========================================='
                echo 'SONARQUBE ANALYSIS WITH COVERAGE'
                echo '========================================='
                dir('backend') {
                    script {
                        def scannerHome = tool 'SonarQube Scanner'
                        withSonarQubeEnv('SonarQube') {
                            sh """
                                ${scannerHome}/bin/sonar-scanner \
                                -Dsonar.projectKey=gestionprojeet \
                                -Dsonar.sources=src/main/java \
                                -Dsonar.java.binaries=target/classes \
                                -Dsonar.language=java \
                                -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
                            """
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                echo '========================================='
                echo 'QUALITY GATE CHECK'
                echo '========================================='
                timeout(time: 5, unit: 'MINUTES') {
                    script {
                        def qg = waitForQualityGate()
                        if (qg.status != 'OK') {
                            error "Quality Gate failed: ${qg.status}"
                        }
                        echo "✅ Quality Gate PASSED"
                    }
                }
            }
        }

        stage('Archive Artifacts') {
            steps {
                echo '========================================='
                echo 'ARCHIVE BUILD ARTIFACTS'
                echo '========================================='
                archiveArtifacts(
                    artifacts: 'backend/target/*.jar',
                    fingerprint: true,
                    onlyIfSuccessful: true
                )
            }
        }

        stage('Docker Build & Push') {
            steps {
                echo '========================================='
                echo 'DOCKER BUILD & PUSH'
                echo '========================================='
                dir('backend') {
                    script {
                        def imageTag = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()

                        sh "docker build -t ${DOCKER_IMAGE}:latest ."
                        sh "docker build -t ${DOCKER_IMAGE}:${imageTag} ."

                        withCredentials([usernamePassword(credentialsId: 'docker-credentials', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                            sh 'echo ${DOCKER_PASS} | docker login -u ${DOCKER_USER} --password-stdin'
                            sh "docker push ${DOCKER_IMAGE}:latest"
                            sh "docker push ${DOCKER_IMAGE}:${imageTag}"
                        }
                    }
                }
            }
        }

        stage('Docker Security Scan') {
            steps {
                echo '========================================='
                echo 'DOCKER SECURITY SCAN WITH TRIVY'
                echo '========================================='
                script {
                    def imageTag = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()

                    sh """
                        docker run --rm \
                            -v /var/run/docker.sock:/var/run/docker.sock \
                            aquasec/trivy:latest image \
                            --severity HIGH,CRITICAL \
                            ${DOCKER_IMAGE}:${imageTag}
                    """
                }
            }
        }

        stage('Update K8s Manifests') {
            steps {
                echo '========================================='
                echo 'UPDATE KUBERNETES MANIFESTS'
                echo '========================================='
                script {
                    def imageTag = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                    sh """
                        sed -i 's|image: nourlassoued/gestionprojeet:.*|image: nourlassoued/gestionprojeet:${imageTag}|g' kubernetes-manifests/gestionprojeet-deployment.yaml
                    """
                }
            }
        }

        stage('Commit & Push to Git') {
            steps {
                echo '========================================='
                echo 'COMMIT & PUSH TO GIT'
                echo '========================================='
                script {
                    def imageTag = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                    withCredentials([usernamePassword(credentialsId: 'github-token', usernameVariable: 'GIT_USER', passwordVariable: 'GIT_PASS')]) {
                        sh """
                            git config user.email "jenkins@example.com"
                            git config user.name "Jenkins Bot"
                            git add kubernetes-manifests/gestionprojeet-deployment.yaml
                            git commit -m "🚀 Update GestionProjet image to ${imageTag}" || true
                            git push https://${GIT_USER}:${GIT_PASS}@github.com/NourLassoued/ProjetGestionPro.git HEAD:main
                        """
                    }
                }
            }
        }

        stage('Trigger Argo CD Sync') {
            steps {
                echo '========================================='
                echo 'TRIGGER ARGO CD SYNC'
                echo '========================================='
                sh """
                    echo 'Argo CD will auto-sync via webhook'
                    echo 'Application: gestionprojeet'
                    echo 'Status: Syncing...'
                """
            }
        }

        stage('Summary') {
            steps {
                echo '========================================='
                echo '✅ PIPELINE COMPLETED SUCCESSFULLY!'
                echo '========================================='
                script {
                    def imageTag = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                    echo "Image: nourlassoued/gestionprojeet:${imageTag}"
                    echo 'Git: Updated ✅'
                    echo 'SonarQube: Quality Gate PASSED ✅'
                    echo 'Tests: Executed ✅'
                    echo 'Coverage: Published ✅'
                    echo 'Security: Scanned ✅'
                    echo 'Argo CD: Syncing...'
                }
                echo '========================================='
            }
        }
    }

    post {
        always {
            echo 'Pipeline finished'
            cleanWs()
        }
        success {
            echo '✅ BUILD SUCCESS'
        }
        failure {
            echo '❌ BUILD FAILURE'
        }
    }
}